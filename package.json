  "repository": {
    "type": "git",
    "url": "https://github.com/Pedroohlr/pepsdoc"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
